{
  "name": "@circle-fin/x402-batching",
  "version": "3.2.0",
  "description": "Gasless, batched settlement for x402 payments via Circle Gateway.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "packageManager": "npm@11.10.0",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts --fix",
    "lint:check": "eslint . --ext .ts",
    "format": "prettier --config .prettierrc --write \"**/*.{ts,js,json}\"",
    "format:check": "prettier --config .prettierrc --check \"**/*.{ts,js,json}\"",
    "gen:private-key": "node -e \"console.log('0x' + require('crypto').randomBytes(32).toString('hex'))\""
  },
  "keywords": [
    "x402",
    "circle",
    "gateway",
    "payments",
    "usdc",
    "batching"
  ],
  "license": "Apache-2.0",
  "author": "Circle Internet Financial",
  "peerDependencies": {
    "@x402/core": "^2.3.0",
    "@x402/evm": "^2.3.0",
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@x402/evm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@x402/evm": "^2.3.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "@types/node": "^22.13.4",
    "tsup": "^8.4.0",
    "typescript-eslint": "^8.22.0",
    "typescript": "^5.7.3",
    "viem": "^2.52.0",
    "vitest": "^4.1.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client/index.d.mts",
        "default": "./dist/client/index.mjs"
      },
      "require": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.js"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.mts",
        "default": "./dist/server/index.mjs"
      },
      "require": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "overrides": {
    "@babel/parser": "7.28.5",
    "@babel/types": "7.28.5"
  }
}
